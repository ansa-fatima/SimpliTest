// SimpliTest — Prisma schema
//   npx prisma db push       fast iteration
//   npx prisma migrate dev   create + apply migration
//   npx prisma studio        visual DB browser
//   npm run db:seed          seed initial modules

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ────────────────────────────────────────────────────────────
// Auth — Users & Sessions
// ────────────────────────────────────────────────────────────

enum UserRole {
  SuperAdmin
  QAManager
  Tester
  Developer
  Viewer
}

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  email        String    @unique
  passwordHash String?
  name         String    @default("")
  avatarUrl    String?
  googleId     String?   @unique
  microsoftId  String?   @unique
  role         UserRole   @default(Tester)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  sessions     Session[]
  ownedCases   TestCase[]   @relation("OwnedTestCases")
  memberships  Membership[]
  sentInvites  Invite[]     @relation("SentInvites")

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("sessions")
}

// ────────────────────────────────────────────────────────────
// Hierarchy:  Project > Portal > Module > Suite > TestCase
//   Project  ≈ Platform (Web / Mobile / Desktop)
//   Portal   ≈ Product   (Admin / Teacher / Student / Parent app, etc.)
// ────────────────────────────────────────────────────────────

// Top-level grouping — also doubles as the "workspace / team" the user signs into.
// Members are users with a Membership row; invites are pending email-based joins.
model Project {
  id          String       @id @default(cuid())
  name        String       @unique
  slug        String       @unique
  portals     Portal[]
  cycles      TestCycle[]
  memberships Membership[]
  invites     Invite[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("projects")
}

// User ↔ workspace link. `role` is the user's effective role inside this workspace.
model Membership {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role      UserRole @default(Tester)
  joinedAt  DateTime @default(now())

  @@unique([userId, projectId])
  @@index([projectId])
  @@map("memberships")
}

enum InviteStatus {
  Pending
  Accepted
  Revoked
  Expired
}

// Pending invitation. Token is the shareable acceptance URL fragment.
model Invite {
  id          String       @id @default(cuid())
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  email       String
  role        UserRole     @default(Tester)
  token       String       @unique
  status      InviteStatus @default(Pending)
  invitedById String
  invitedBy   User         @relation("SentInvites", fields: [invitedById], references: [id])
  acceptedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime     @default(now())

  @@index([projectId])
  @@index([email])
  @@index([status])
  @@map("invites")
}

// A portal or app inside a platform.
// e.g. "Admin Portal" / "Teacher Web" / "Parent Mobile" / "Attendance Desktop".
model Portal {
  id        String     @id @default(cuid())
  name      String
  slug      String?
  icon      String?    // Tabler icon name, e.g. "ti-presentation"
  projectId String
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  modules   Module[]
  testCases TestCase[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([projectId, name])
  @@index([projectId])
  @@map("portals")
}

model Module {
  id        String     @id @default(cuid())
  name      String
  portalId  String
  portal    Portal     @relation(fields: [portalId], references: [id], onDelete: Cascade)
  suites    Suite[]
  testCases TestCase[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([portalId, name])
  @@index([portalId])
  @@map("modules")
}

// Was "Feature" — renamed to "Suite" for PRD alignment.
// DB table is still named `features` (kept via @@map) so no data migration is
// required for the rename itself.
// Renamed conceptually to "Folder" — a node in the recursive test-case tree.
// Each suite belongs to a module, but can also have a parent suite for arbitrary
// nesting (a → b → c → d). Test cases attach to any node in this tree.
//
// Uniqueness within a parent is enforced in the API layer because Postgres
// composite uniques treat NULL parents as non-equal (so a strict @@unique
// wouldn't catch sibling-name collisions at the module root).
model Suite {
  id        String     @id @default(cuid())
  name      String
  module    Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId  String
  parentId  String?
  parent    Suite?     @relation("SuiteTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  Suite[]    @relation("SuiteTree")
  testCases TestCase[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([moduleId])
  @@index([parentId])
  @@map("features")
}

// ────────────────────────────────────────────────────────────
// 1.3  Test Cases
// ────────────────────────────────────────────────────────────

enum Priority {
  High
  Medium
  Low
}

enum Severity {
  Critical
  Major
  Minor
}

enum TestType {
  Functional
  Regression
  Smoke
  Sanity
  UI
  API
}

enum CaseStatus {
  Active
  Draft
  Archived
}

model TestCase {
  id            String     @id @default(cuid())
  caseNum       Int        @unique @default(autoincrement())
  title         String
  sub           String     @default("")
  desc          String     @default("")
  preconditions String     @default("")
  steps         Json
  expected      String     @default("")
  priority      Priority
  severity      Severity
  type          TestType
  status        CaseStatus @default(Active)
  // A test case attaches to exactly ONE of: Portal, Module, or Suite.
  // App-layer validation enforces "exactly one set" — Postgres can't express
  // an XOR constraint cleanly across three FKs without a CHECK constraint.
  // DB column is still named "featureId" (mapped) — Prisma model uses suiteId.
  portal    Portal?    @relation(fields: [portalId], references: [id], onDelete: Cascade)
  portalId  String?
  module    Module?    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId  String?
  suite     Suite?     @relation(fields: [suiteId], references: [id], onDelete: Cascade)
  suiteId   String?    @map("featureId")
  author    String     @default("")
  // Optional assigned owner (a user) — shown as avatar in the OWNER column.
  owner     User?      @relation("OwnedTestCases", fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId   String?
  runs      TestRun[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([portalId])
  @@index([moduleId])
  @@index([suiteId])
  @@index([priority])
  @@index([severity])
  @@index([type])
  @@index([status])
  @@index([ownerId])
  @@map("test_cases")
}

// ────────────────────────────────────────────────────────────
// Test Cycles & Runs
// ────────────────────────────────────────────────────────────

enum RunResult {
  NotRun
  Passed
  Failed
  Blocked
  Skipped
}

enum CycleStatus {
  Active
  Completed
  Archived
}

enum CycleScopeType {
  All
  Portal
  Module
  Suite
  Custom
}

// CaseBased = the existing per-test-case execution flow (creates a TestRun per case).
// Manual    = a quick-log entry — track aggregate pass/fail/severity counts against
//             a free-text Module + Feature, no TestRun rows required.
enum CycleMode {
  CaseBased
  Manual
}

model TestCycle {
  id          String         @id @default(cuid())
  name        String
  description String         @default("")
  status      CycleStatus    @default(Active)
  mode        CycleMode      @default(CaseBased)
  scopeType   CycleScopeType @default(All)
  scopeId     String?        // moduleId or suiteId; null for All / Custom
  targetDate  DateTime?
  // When this cycle was actually executed. For Manual (quick-log) entries the
  // user picks it explicitly so back-dated cycles show up on the day they ran.
  // For CaseBased cycles it's left null until the run is closed.
  completedAt DateTime?
  projectId   String
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  runs        TestRun[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Manual-mode bookkeeping — free-text so users can record cycles before
  // defining the workspace's module/feature structure. Ignored for CaseBased cycles.
  portalName     String?
  moduleName     String?
  featureName    String?
  environment    String? // Production / QA / Staging / Dev
  platform       String? // Android / iPhone / Web / All / Desktop
  version        String? // app version under test
  cycleCategory  String? // Stability / Regression / Functional / UI / Performance
  ticketLink     String?

  // Aggregate counts for Manual cycles. CaseBased cycles derive these from runs[].
  issueCount     Int @default(0) // total defects found
  criticalCount  Int @default(0)
  majorCount     Int @default(0)
  minorCount     Int @default(0)
  doneCount      Int @default(0) // defects resolved
  remainingCount Int @default(0) // defects still open
  passedCount    Int @default(0) // test cases passed
  failedCount    Int @default(0) // test cases failed
  blockedCount   Int @default(0) // test cases blocked

  @@index([status])
  @@index([projectId])
  @@index([mode])
  @@map("test_cycles")
}

model TestRun {
  id         String    @id @default(cuid())
  cycle      TestCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  cycleId    String
  testCase   TestCase  @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  testCaseId String
  result     RunResult @default(NotRun)
  notes      String    @default("")
  executedAt DateTime?
  executedBy String    @default("")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([cycleId, testCaseId])
  @@index([cycleId])
  @@index([result])
  @@map("test_runs")
}
