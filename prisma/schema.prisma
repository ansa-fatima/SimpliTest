// SimpliTest — Prisma schema
//   npx prisma db push       fast iteration
//   npx prisma migrate dev   create + apply migration
//   npx prisma studio        visual DB browser
//   npm run db:seed          seed initial modules

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ────────────────────────────────────────────────────────────
// Auth — Users & Sessions
// ────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  email        String    @unique
  passwordHash String?
  name         String    @default("")
  avatarUrl    String?
  googleId     String?   @unique
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("sessions")
}

// ────────────────────────────────────────────────────────────
// 1.2  Modules & Features
// ────────────────────────────────────────────────────────────

model Module {
  id        String    @id @default(cuid())
  name      String    @unique
  features  Feature[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("modules")
}

model Feature {
  id        String     @id @default(cuid())
  name      String
  module    Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId  String
  testCases TestCase[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([moduleId, name])
  @@index([moduleId])
  @@map("features")
}

// ────────────────────────────────────────────────────────────
// 1.3  Test Cases
// ────────────────────────────────────────────────────────────

enum Priority {
  High
  Medium
  Low
}

enum Severity {
  Critical
  Major
  Minor
}

enum TestType {
  Functional
  Regression
  Smoke
  Sanity
  UI
  API
}

model TestCase {
  id        String    @id @default(cuid())
  caseNum   Int       @unique @default(autoincrement())
  title     String
  sub       String    @default("")
  desc      String    @default("")
  steps     Json
  expected  String    @default("")
  priority  Priority
  severity  Severity
  type      TestType
  feature   Feature   @relation(fields: [featureId], references: [id], onDelete: Cascade)
  featureId String
  author    String    @default("")
  runs      TestRun[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([featureId])
  @@index([priority])
  @@index([severity])
  @@index([type])
  @@map("test_cases")
}

// ────────────────────────────────────────────────────────────
// Test Cycles & Runs
// ────────────────────────────────────────────────────────────

enum RunResult {
  NotRun
  Passed
  Failed
  Blocked
  Skipped
}

enum CycleStatus {
  Active
  Completed
  Archived
}

enum CycleScopeType {
  All
  Module
  Feature
  Custom
}

model TestCycle {
  id          String         @id @default(cuid())
  name        String
  description String         @default("")
  status      CycleStatus    @default(Active)
  scopeType   CycleScopeType @default(All)
  scopeId     String?        // moduleId or featureId; null for All / Custom
  targetDate  DateTime?
  runs        TestRun[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status])
  @@map("test_cycles")
}

model TestRun {
  id         String    @id @default(cuid())
  cycle      TestCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  cycleId    String
  testCase   TestCase  @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  testCaseId String
  result     RunResult @default(NotRun)
  notes      String    @default("")
  executedAt DateTime?
  executedBy String    @default("")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([cycleId, testCaseId])
  @@index([cycleId])
  @@index([result])
  @@map("test_runs")
}
