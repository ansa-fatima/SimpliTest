DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# DESTRUCTIVE — opt-in DB reset on container startup.
#   false (default): startup runs `prisma migrate deploy` (with `db push` fallback).
#   true:            startup DROPs the public schema, re-applies all migrations,
#                    and re-seeds. ALL DATA IS LOST. Use this to recover from a
#                    corrupted DB or to refresh the demo dataset.
# Set true once, redeploy, then flip back to false — otherwise every deploy wipes the DB.
SEED_DATA=false

# Optional: Google OAuth. Leave blank to hide the "Continue with Google" button.
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"
